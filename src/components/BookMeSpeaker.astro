<style>
	.book-me-speaker {
		border: 2px solid var(--accent);
		border-radius: 0.5rem;
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.book-me-speaker-heading {
		font-size: 1.1rem;
		font-weight: 500;
		color: var(--text-primary);
	}

	.book-me-speaker-text {
		font-size: 1rem;
		line-height: 1.6;
		color: var(--text-primary);
	}

	.book-me-speaker-link {
		color: var(--accent);
		text-decoration: none;
		position: relative;
		width: fit-content;
	}

	.book-me-speaker-link::after {
		content: "";
		position: absolute;
		width: 100%;
		height: 2px;
		bottom: 0;
		left: 0;
		background-color: var(--accent);
		transform: scaleX(0);
		transform-origin: bottom right;
		transition: transform 0.3s ease-in;
	}

	.book-me-speaker-link:hover::after {
		transform: scaleX(1);
		transform-origin: bottom left;
	}
</style>

<div class="book-me-speaker">
	<p class="book-me-speaker-heading">Book me as a speaker</p>
	<p class="book-me-speaker-text">
		I speak at conferences and events on open source sustainability, Node.js,
		web standards, and developer community building. If you're organizing an
		event and think there's a fit, reach out at <a
			class="book-me-speaker-link"
			href="mailto:ethan@arrowood.dev">ethan@arrowood.dev</a
		>.
	</p>
</div>
