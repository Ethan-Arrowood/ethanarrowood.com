---
import type { MarkdownInstance } from "astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import TalkCard from "../components/TalkCard.astro";
import BookMeSpeaker from "../components/BookMeSpeaker.astro";
import type { TalkFrontmatter } from "../utils/talkfrontmatter";

const allTalks = Object.values(
	import.meta.glob<MarkdownInstance<TalkFrontmatter>>("./talks/*.md", {
		eager: true,
	}),
);

const now = new Date();

const upcoming = allTalks.filter((talk) =>
	talk.frontmatter.events.some((e) => new Date(e.date) >= now),
);

const past = allTalks.filter((talk) =>
	talk.frontmatter.events.every((e) => new Date(e.date) < now),
);
---

<style>
	section {
		border-block-end: var(--accent) solid 2px;
		padding-block: 2rem;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	section:first-of-type {
		padding-block-start: 0;
	}

	section:last-of-type {
		border-block-end: none;
		padding-block-end: 0;
	}

	h2 {
		font-weight: 500;
	}

	.talks-list {
		list-style-type: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
</style>

<BaseLayout title="Talks">
	{
		upcoming.length > 0 && (
			<section>
				<h2>Upcoming</h2>
				<ul class="talks-list">
					{upcoming.map((talk) => (
						<li>
							<TalkCard talk={talk} />
						</li>
					))}
				</ul>
			</section>
		)
	}
	<section>
		<h2>Past Talks</h2>
		{
			past.length > 0 ? (
				<ul class="talks-list">
					{past.map((talk) => (
						<li>
							<TalkCard talk={talk} />
						</li>
					))}
				</ul>
			) : (
				<p>Past talks coming soon.</p>
			)
		}
	</section>
	<section>
		<BookMeSpeaker />
	</section>
</BaseLayout>
