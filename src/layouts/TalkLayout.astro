---
import BaseLayout from "./BaseLayout.astro";
import BookMeSpeaker from "../components/BookMeSpeaker.astro";
import type { TalkEvent } from "../utils/talkfrontmatter";
import "../styles/post.css";
import "../styles/talk.css";

const { frontmatter } = Astro.props;

const now = new Date();

const events = (frontmatter.events as TalkEvent[])
	.map((event) => ({
		...event,
		isUpcoming: new Date(event.date) >= now,
	}))
	// Upcoming events first, then most recent past events.
	.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
	<section class="talk-container">
		<div class="talk-header">
			<h1 class="talk-title">{frontmatter.title}</h1>
			<dl class="talk-meta">
				{frontmatter.audienceLevel && (
					<>
						<dt class="talk-meta-label">Audience Level</dt>
						<dd class="talk-meta-value">{frontmatter.audienceLevel}</dd>
					</>
				)}
				{frontmatter.sessionFormat && (
					<>
						<dt class="talk-meta-label">Session Format</dt>
						<dd class="talk-meta-value">{frontmatter.sessionFormat}</dd>
					</>
				)}
			</dl>
			<div class="talk-events">
				{
					events.map((event) => (
						<div class="talk-event">
							<div class="talk-event-heading">
								<span class="talk-event-name">{event.name}</span>
								<span
									class:list={[
										"talk-event-status",
										event.isUpcoming ? "is-upcoming" : "is-past",
									]}
								>
									{event.isUpcoming ? "Upcoming" : "Past"}
								</span>
							</div>
							<span class="talk-event-date">{event.date}</span>
							<div class="talk-event-links">
								<a href={event.eventUrl} target="_blank" rel="noreferrer">
									Event site
								</a>
								{event.talkUrl && (
									<a href={event.talkUrl} target="_blank" rel="noreferrer">
										Talk page
									</a>
								)}
								{event.videoUrl && (
									<a href={event.videoUrl} target="_blank" rel="noreferrer">
										Watch recording
									</a>
								)}
								{event.slidesUrl && (
									<a href={event.slidesUrl} target="_blank" rel="noreferrer">
										Slides
									</a>
								)}
							</div>
						</div>
					))
				}
			</div>
		</div>

		<div class="post-content">
			<slot />
		</div>

		<BookMeSpeaker />
	</section>
</BaseLayout>

<script>
	import("@justinribeiro/lite-youtube/lite-youtube.js");
</script>
