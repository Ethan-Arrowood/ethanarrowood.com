---
import ogImage from "../images/mountain-landscape.jpg";

interface Props {
	title?: string;
	description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ? `${title} | Ethan Arrowood` : "Ethan Arrowood";
const defaultDescription =
	"Personal website for Ethan Arrowood. Head of Open Source Engineering at Harper. Node.js contributor. OpenJS Foundation and WinterTC collaborator. Breckenridge ski instructor.";
const pageDescription = description || defaultDescription;
---

<style is:global>
	:root {
		--background: #f5f5f1;
		--accent: #2d8b72;
		--text-primary: #1a1a1a;
		--text-secondary: #666666;
		--code-bg: #d4d4d4;
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}
</style>

<style>
	body {
		font-family: sans-serif;
		min-height: 100vh;
		background-color: var(--background);
		font-size: 16px;
		display: flex;
		flex-direction: column;
	}

	header {
		margin: auto;
		width: 100%;
		padding: 2rem 1rem;
		display: flex;
		flex-direction: column;
		align-items: start;
		gap: 2rem;
		border-block-end: var(--accent) solid 2px;
	}

	nav {
		display: flex;
		flex-direction: row;
		gap: 1rem;
	}

	.title {
		display: block;
		font-size: 2rem;
		font-weight: 500;
		color: var(--accent);
	}

	.tagline {
		font-size: 1rem;
		font-weight: 500;
		font-style: italic;
		color: var(--text-secondary);
	}

	nav > a {
		color: var(--text-primary);
		text-decoration: none;
	}

	nav > a:hover {
		color: var(--accent);
	}

	nav > a.disabled {
		color: var(--text-secondary);
		cursor: default;
	}

	nav > a.disabled:hover {
		color: var(--text-secondary);
	}

	main {
		width: 100%;
		margin: auto;
		flex: 1;
		display: flex;
		flex-direction: column;
		padding: 2rem 1rem;
	}

	footer {
		margin: auto;
		width: 100%;
		padding: 2rem 1rem;
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		border-block-start: var(--accent) solid 2px;
	}

	footer .socials {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	footer .socials a {
		display: inline-flex;
		color: var(--text-primary);
		transition: color 0.2s ease;
	}

	footer .socials a:hover {
		color: var(--accent);
	}

	footer .socials svg {
		width: 1.5rem;
		height: 1.5rem;
	}

	footer p {
		align-items: center;
		display: inline-flex;
	}

	footer p svg {
		margin-inline: 0.25rem;
		display: inline-block;
		width: 1.25rem;
		height: 1.25rem;
	}

	/* Small */
	@media (min-width: 640px) {
		header,
		main,
		footer {
			width: 640px;
			padding-inline: 0;
		}

		header {
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
		}
	}

	/* Medium */
	@media (min-width: 768px) {
		header,
		main,
		footer {
			width: 768px;
		}
	}

	/* Large */
	@media (min-width: 1024px) {
		header,
		main,
		footer {
			width: 1024px;
		}
	}
</style>

<html>
	<head>
		<meta charset="utf-8" />
		<meta name="author" content="Ethan Arrowood" />
		<meta name="description" content={pageDescription} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url.href} />
		<meta property="og:locale" content="en_US" />
		<meta property="og:image" content={new URL(ogImage.src, Astro.site)} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<link
			rel="icon"
			href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🏔️</text></svg>"
		/>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/katex@0.15.2/dist/katex.min.css"
			integrity="sha384-MlJdn/WNKDGXveldHDdyRP1R4CTHr3FeuDNfhsLPYrq2t0UBkUdK2jyTnXPEK1NQ"
			crossorigin="anonymous"
		/>
		<!-- Google Analytics (Production only) -->
		{import.meta.env.PROD && (
			<>
				<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-FKHLX85PGZ"></script>
				<script is:inline>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());

					gtag('config', 'G-FKHLX85PGZ');
				</script>
			</>
		)}
		<title>{pageTitle}</title>
	</head>
	<body>
		<header>
			<div>
				<h1 class="title">Ethan Arrowood</h1>
				<h2 class="tagline">Optimizing Systems, Organizing Communities, Overcoming Summits</h2>
			</div>
			<nav>
				<a href="/">home</a>
				<a href="/blog">blog</a>
				<a href="/talks">talks</a>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer>
			<div class="socials">
				<a
					href="https://github.com/Ethan-Arrowood"
